# ── Agent Management ──────────────────────────────────────────────────────────
cmd_set_token() {
  local agent_id="$1"
  local token="$2"

  if [ -z "$agent_id" ] || [ -z "$token" ]; then
    err "Usage: tamerclaw set-token <agentId> <botToken>"
    exit 1
  fi

  node -e "
    const fs = require('fs');
    const configPath = '$SCRIPT_DIR/user/config.json';
    const c = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
    if (!c.agents['$agent_id']) {
      console.error('Agent not found: $agent_id');
      process.exit(1);
    }
    c.agents['$agent_id'].botToken = '$token';
    fs.writeFileSync(configPath, JSON.stringify(c, null, 2));
    console.log('✅ Token set for $agent_id');
  "
}

cmd_agents() {
  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  echo -e "${BOLD}Configured agents:${NC}"
  echo ""
  node -e "
    const fs = require('fs');
    const c = JSON.parse(fs.readFileSync('$SCRIPT_DIR/user/config.json','utf-8'));
    for (const [id, a] of Object.entries(c.agents)) {
      const token = a.botToken ? '✅ token set' : '❌ no token';
      const model = a.model || c.defaults?.model || 'claude-sonnet-4-6';
      const ws = a.workspace || a.standalonePath || '(supreme)';
      console.log('  ' + id.padEnd(18) + token.padEnd(16) + model);
      if (ws) console.log('    ' + ws);
    }
  " 2>/dev/null
}

