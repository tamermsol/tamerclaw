# ── Update Command ────────────────────────────────────────────────────────────
cmd_update() {
  banner

  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  info "Checking for updates..."

  # Check if we're in a git repo
  if [ ! -d "$SCRIPT_DIR/.git" ]; then
    err "Not a git repository. Updates require git."
    echo "    If you installed manually, re-clone the repo and copy your user/ directory."
    exit 1
  fi

  # Record pre-pull HEAD for diffing
  local old_head
  old_head=$(git -C "$SCRIPT_DIR" rev-parse HEAD 2>/dev/null || echo "")
  local old_version="$VERSION"

  # Fetch latest from origin
  git -C "$SCRIPT_DIR" fetch origin main 2>/dev/null || {
    err "Failed to fetch updates. Check your internet connection."
    exit 1
  }

  # Check if already up to date
  local remote_head
  remote_head=$(git -C "$SCRIPT_DIR" rev-parse origin/main 2>/dev/null || echo "")

  if [ "$old_head" = "$remote_head" ]; then
    # Even if code is up to date, check if services need repair
    local svc_ok=true
    for svc in "$SVC_BRIDGE" "$SVC_SUPREME"; do
      if ! $SCTL cat "$svc" &>/dev/null; then
        svc_ok=false
        break
      fi
    done
    if $svc_ok; then
      info "Already up to date (v${VERSION})"
      return
    fi
    warn "Code is up to date but services need repair — regenerating..."
  fi

  # Force-update local to match upstream (safe: user data is in gitignored user/)
  info "Applying updates..."
  git -C "$SCRIPT_DIR" reset --hard origin/main 2>/dev/null || {
    err "Failed to apply updates."
    exit 1
  }

  local new_version
  new_version=$(node -e "console.log(JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/version.json','utf-8')).version)" 2>/dev/null || echo "unknown")

  # Show what changed
  local commits_pulled
  commits_pulled=$(git -C "$SCRIPT_DIR" log --oneline "${old_head}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
  info "Pulled $commits_pulled new commit(s)"

  # ── Migrate runtime state from core/ to user/ (v1.10+ isolation fix) ──────
  if [ -f "$SCRIPT_DIR/user/config.json" ]; then
    # Create new runtime directories
    mkdir -p "$SCRIPT_DIR/user/relay/outbox" "$SCRIPT_DIR/user/relay/stream-outbox"
    mkdir -p "$SCRIPT_DIR/user/agents/supreme/outbox"

    # Migrate relay runtime files
    for f in inbox.jsonl processed.txt current-agent.txt processing.json session-owners.json agent-sessions.json health.json bot.lock; do
      if [ -f "$SCRIPT_DIR/core/relay/$f" ]; then
        mv "$SCRIPT_DIR/core/relay/$f" "$SCRIPT_DIR/user/relay/$f" 2>/dev/null && \
          info "Migrated relay/$f → user/relay/" || true
      fi
    done
    # Migrate relay outbox contents
    if [ -d "$SCRIPT_DIR/core/relay/outbox" ] && ls "$SCRIPT_DIR/core/relay/outbox/"*.json &>/dev/null 2>&1; then
      mv "$SCRIPT_DIR/core/relay/outbox/"*.json "$SCRIPT_DIR/user/relay/outbox/" 2>/dev/null && \
        info "Migrated relay/outbox/ → user/relay/outbox/" || true
    fi
    if [ -d "$SCRIPT_DIR/core/relay/stream-outbox" ] && ls "$SCRIPT_DIR/core/relay/stream-outbox/"*.json &>/dev/null 2>&1; then
      mv "$SCRIPT_DIR/core/relay/stream-outbox/"*.json "$SCRIPT_DIR/user/relay/stream-outbox/" 2>/dev/null && \
        info "Migrated relay/stream-outbox/ → user/relay/stream-outbox/" || true
    fi

    # Migrate supreme runtime files
    for f in inbox.jsonl processed.txt processing.json health.json bot.lock; do
      if [ -f "$SCRIPT_DIR/core/supreme/$f" ]; then
        mv "$SCRIPT_DIR/core/supreme/$f" "$SCRIPT_DIR/user/agents/supreme/$f" 2>/dev/null && \
          info "Migrated supreme/$f → user/agents/supreme/" || true
      fi
    done
    if [ -d "$SCRIPT_DIR/core/supreme/outbox" ] && ls "$SCRIPT_DIR/core/supreme/outbox/"*.json &>/dev/null 2>&1; then
      mv "$SCRIPT_DIR/core/supreme/outbox/"*.json "$SCRIPT_DIR/user/agents/supreme/outbox/" 2>/dev/null && \
        info "Migrated supreme/outbox/ → user/agents/supreme/outbox/" || true
    fi

    # Migrate shared state files
    if [ -f "$SCRIPT_DIR/core/relay/proxy-state.json" ]; then
      mv "$SCRIPT_DIR/core/relay/proxy-state.json" "$SCRIPT_DIR/user/proxy-state.json" 2>/dev/null && \
        info "Migrated proxy-state.json → user/" || true
    fi
    if [ -f "$SCRIPT_DIR/core/shared/rate-usage.json" ]; then
      mv "$SCRIPT_DIR/core/shared/rate-usage.json" "$SCRIPT_DIR/user/rate-usage.json" 2>/dev/null && \
        info "Migrated rate-usage.json → user/" || true
    fi
  fi

  # Always reinstall dependencies after update to avoid stale/corrupt node_modules
  info "Installing/updating dependencies..."
  (cd "$SCRIPT_DIR/core/bridge" && npm install --silent 2>&1 | tail -3) || warn "Bridge npm install had issues"
  (cd "$SCRIPT_DIR/core/supreme" && npm install --silent 2>&1 | tail -3) || warn "Supreme npm install had issues"

  # Regenerate systemd service files (paths/configs may have changed)
  if [ -f "$SCRIPT_DIR/user/config.json" ]; then
    info "Regenerating systemd service files..."

    local claude_bin_dir
    claude_bin_dir=$(dirname "$(get_claude_path)" 2>/dev/null || echo "")
    local svc_path="$PATH"
    if [ -n "$claude_bin_dir" ] && [[ ":$svc_path:" != *":$claude_bin_dir:"* ]]; then
      svc_path="$claude_bin_dir:$svc_path"
    fi
    for p in "$HOME/.local/bin" "/usr/local/bin" "/usr/bin"; do
      [[ ":$svc_path:" != *":$p:"* ]] && svc_path="$p:$svc_path"
    done

    local svc_user_line=""
    if [ "$SYSTEMD_MODE" = "system" ] && [ "$(id -u)" -ne 0 ]; then
      svc_user_line="User=$(whoami)
Group=$(id -gn)"
    fi

    # Migrate old services if needed
    migrate_old_services

    write_service_file "${SVC_BRIDGE}.service" "[Unit]
Description=TamerClaw Bridge [${TC_USER}] (Telegram ↔ Claude Code)
After=network.target

[Service]
Type=simple
${svc_user_line}
WorkingDirectory=$SCRIPT_DIR/core/bridge
ExecStart=$(which node) index.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
Environment=TAMERCLAW_HOME=$SCRIPT_DIR
Environment=HOME=$HOME
Environment=PATH=$svc_path
StandardOutput=journal
StandardError=journal
SyslogIdentifier=$SVC_BRIDGE

[Install]
WantedBy=$SVC_WANTED_BY"

    write_service_file "${SVC_SUPREME}.service" "[Unit]
Description=TamerClaw Supreme Agent [${TC_USER}]
After=network.target

[Service]
Type=simple
${svc_user_line}
WorkingDirectory=$SCRIPT_DIR/core/supreme
ExecStart=$(which node) bot.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
Environment=TAMERCLAW_HOME=$SCRIPT_DIR
Environment=HOME=$HOME
Environment=PATH=$svc_path
StandardOutput=journal
StandardError=journal
SyslogIdentifier=$SVC_SUPREME

[Install]
WantedBy=$SVC_WANTED_BY"
  fi

  # Reload systemd after regenerating service files
  $SCTL daemon-reload 2>/dev/null || true

  # Safe-restart only services that exist AND were running
  local services_restarted=0
  for svc in "$SVC_BRIDGE" "$SVC_SUPREME"; do
    if $SCTL cat "$svc" &>/dev/null && $SCTL is-active "$svc" &>/dev/null; then
      info "Restarting $svc..."
      if safe_restart_service "$svc"; then
        services_restarted=$((services_restarted + 1))
      fi
    fi
  done

  if [ "$services_restarted" -gt 0 ]; then
    info "$services_restarted service(s) restarted"
  fi

  # ── Write update notification for Supreme Agent to announce ──────────────
  if [ "$old_head" != "$remote_head" ] && [ -d "$SCRIPT_DIR/user/agents/supreme" ]; then
    local notify_file="$SCRIPT_DIR/user/agents/supreme/update-notify.json"
    local commits_json="["
    local first=true
    while IFS= read -r line; do
      # Escape double quotes in commit messages for JSON
      local escaped
      escaped=$(echo "$line" | sed 's/"/\\"/g')
      if $first; then
        commits_json="$commits_json\"$escaped\""
        first=false
      else
        commits_json="$commits_json,\"$escaped\""
      fi
    done < <(git -C "$SCRIPT_DIR" log --oneline "${old_head}..HEAD" 2>/dev/null | head -10)
    commits_json="$commits_json]"

    cat > "$notify_file" <<NOTIFY_EOF
{
  "oldVersion": "${old_version}",
  "newVersion": "${new_version}",
  "commits": ${commits_json},
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
NOTIFY_EOF
    info "Supreme Agent will announce the update on restart"
  fi

  echo ""
  info "Updated: v${old_version} → v${new_version}"
  echo ""
  echo "  Changes:"
  git -C "$SCRIPT_DIR" log --oneline "${old_head}..HEAD" 2>/dev/null | head -10 | while read -r line; do
    echo "    $line"
  done
}

# ── Start/Stop/Restart ────────────────────────────────────────────────────────
cmd_start() {
  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  local target="${1:-all}"

  case "$target" in
    bridge)
      $SCTL start "$SVC_BRIDGE"
      info "Bridge started. Logs: $JCTL -u $SVC_BRIDGE -f"
      ;;
    supreme)
      $SCTL start "$SVC_SUPREME"
      info "Supreme Agent started. Logs: $JCTL -u $SVC_SUPREME -f"
      ;;
    all|"")
      if $SCTL start "$SVC_BRIDGE" 2>/dev/null; then
        info "Bridge started"
      else
        warn "Bridge failed to start"
        echo "    Checking logs..."
        $JCTL -u "$SVC_BRIDGE" -n 15 --no-pager 2>/dev/null || true
      fi
      if $SCTL start "$SVC_SUPREME" 2>/dev/null; then
        info "Supreme Agent started"
      else
        warn "Supreme failed to start"
        echo "    Checking logs..."
        $JCTL -u "$SVC_SUPREME" -n 15 --no-pager 2>/dev/null || true
        echo ""
        echo "    Try running manually to debug:"
        echo "      cd $SCRIPT_DIR/core/supreme && TAMERCLAW_HOME=$SCRIPT_DIR node bot.js"
      fi
      echo ""
      info "All services started. Logs: tamerclaw logs"
      ;;
    --foreground)
      local fg_target="${2:-bridge}"
      case "$fg_target" in
        bridge)
          info "Starting bridge in foreground..."
          cd "$SCRIPT_DIR/core/bridge" && TAMERCLAW_HOME="$SCRIPT_DIR" node index.js
          ;;
        supreme)
          info "Starting supreme in foreground..."
          cd "$SCRIPT_DIR/core/supreme" && TAMERCLAW_HOME="$SCRIPT_DIR" node bot.js
          ;;
        *)
          err "Unknown foreground target: $fg_target"
          echo "Usage: tamerclaw start --foreground [bridge|supreme]"
          ;;
      esac
      ;;
    *)
      err "Unknown target: $target"
      echo "Usage: tamerclaw start [bridge|supreme|all|--foreground [bridge|supreme]]"
      ;;
  esac
}

cmd_stop() {
  local target="${1:-all}"
  case "$target" in
    bridge)  $SCTL stop "$SVC_BRIDGE"; info "Bridge stopped" ;;
    supreme) $SCTL stop "$SVC_SUPREME"; info "Supreme stopped" ;;
    all|"")
      $SCTL stop "$SVC_BRIDGE" 2>/dev/null; $SCTL stop "$SVC_SUPREME" 2>/dev/null
      info "All services stopped"
      ;;
  esac
}

# ── Safe Restart Protocol ──────────────────────────────────────────────────────
# Implements graceful shutdown, health checks, and self-protection for restarts.

# Services that the calling agent must NEVER restart (self-protection)
SELF_PROTECTED_SERVICES=("tamerclaw-agent")

# Resolve target name to systemd service name(s)
resolve_services() {
  local target="$1"
  case "$target" in
    bridge)  echo "$SVC_BRIDGE" ;;
    supreme) echo "$SVC_SUPREME" ;;
    all|"")  echo "$SVC_BRIDGE $SVC_SUPREME" ;;
    *)       echo "tamerclaw-${TC_USER}-${target}" ;;
  esac
}

# Check if a service is self-protected (must never be restarted by this process)
is_self_protected() {
  local svc="$1"
  for protected in "${SELF_PROTECTED_SERVICES[@]}"; do
    if [[ "$svc" == "$protected" || "$svc" == "${protected}.service" ]]; then
      return 0
    fi
  done
  return 1
}

# Wait for a service to reach a target state, with timeout
wait_for_state() {
  local svc="$1"
  local target_state="$2"  # "active" or "inactive"
  local timeout="${3:-15}"
  local elapsed=0

  while [ "$elapsed" -lt "$timeout" ]; do
    local state
    state=$($SCTL is-active "$svc" 2>/dev/null || echo "unknown")
    if [ "$state" = "$target_state" ]; then
      return 0
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done
  return 1  # timed out
}

# Get service PID and uptime for pre/post comparison
service_snapshot() {
  local svc="$1"
  local pid uptime_sec
  pid=$($SCTL show "$svc" --property=MainPID --value 2>/dev/null || echo "0")
  uptime_sec=$($SCTL show "$svc" --property=ExecMainStartTimestampMonotonic --value 2>/dev/null || echo "0")
  echo "${pid}:${uptime_sec}"
}

# Perform a safe restart of a single service
safe_restart_service() {
  local svc="$1"
  local max_stop_wait="${2:-15}"
  local max_start_wait="${3:-20}"

  # ── Self-protection gate ──
  if is_self_protected "$svc"; then
    err "BLOCKED: Cannot restart '$svc' — this is a self-protected service."
    err "Restarting it would kill this agent's own process."
    echo "    If you really need to restart it, do it manually:"
    echo "    $SCTL restart $svc"
    return 1
  fi

  # ── Check if service unit exists ──
  if ! $SCTL cat "$svc" &>/dev/null; then
    err "Service '$svc' does not exist."
    return 1
  fi

  # ── Pre-restart snapshot ──
  local was_active=0
  if $SCTL is-active "$svc" &>/dev/null; then
    was_active=1
  fi

  local pre_snapshot
  pre_snapshot=$(service_snapshot "$svc")
  local pre_pid="${pre_snapshot%%:*}"

  if [ "$was_active" -eq 1 ]; then
    info "Stopping $svc (PID $pre_pid)..."

    # Graceful stop (SIGTERM via systemd)
    $SCTL stop "$svc" 2>/dev/null

    # Wait for clean shutdown
    if wait_for_state "$svc" "inactive" "$max_stop_wait"; then
      info "$svc stopped cleanly"
    else
      warn "$svc did not stop within ${max_stop_wait}s — forcing..."
      $SCTL kill "$svc" --signal=SIGKILL 2>/dev/null
      sleep 2
      if $SCTL is-active "$svc" &>/dev/null; then
        err "$svc is still running after SIGKILL. Manual intervention needed."
        return 1
      fi
      info "$svc force-stopped"
    fi
  else
    info "$svc was not running — starting fresh"
  fi

  # ── Start the service ──
  info "Starting $svc..."
  $SCTL start "$svc" 2>/dev/null

  # ── Post-start health check ──
  if wait_for_state "$svc" "active" "$max_start_wait"; then
    local post_snapshot
    post_snapshot=$(service_snapshot "$svc")
    local post_pid="${post_snapshot%%:*}"
    info "$svc is running (PID $post_pid) ✓"
    return 0
  else
    # Service failed to come back up
    local status
    status=$($SCTL is-active "$svc" 2>/dev/null)
    [ -z "$status" ] && status="unknown"
    err "$svc failed to start (status: $status)"
    echo ""
    echo "  Recent logs:"
    $JCTL -u "$svc" --no-pager -n 10 --no-hostname 2>/dev/null || true
    echo ""
    err "Service '$svc' needs manual attention."
    return 1
  fi
}

cmd_restart() {
  local target="${1:-all}"
  local services
  services=$(resolve_services "$target")

  local failed=0
  local skipped=0
  local restarted=0
  for svc in $services; do
    echo ""
    echo -e "${BOLD}── Restarting: $svc ──${NC}"
    # Skip services that haven't been set up yet
    if ! $SCTL cat "$svc" &>/dev/null; then
      warn "Service '$svc' not found — skipping (run './tamerclaw init' to set up services)"
      skipped=$((skipped + 1))
      continue
    fi
    if ! safe_restart_service "$svc"; then
      failed=$((failed + 1))
    else
      restarted=$((restarted + 1))
    fi
  done

  echo ""
  if [ "$failed" -eq 0 ] && [ "$restarted" -gt 0 ]; then
    info "Safe restart complete — $restarted service(s) healthy"
  elif [ "$failed" -eq 0 ] && [ "$restarted" -eq 0 ]; then
    warn "No services to restart. Run './tamerclaw init' first to set up services."
  else
    err "$failed service(s) failed to restart. Check logs above."
  fi
}

# ── Status ────────────────────────────────────────────────────────────────────
cmd_status() {
  banner

  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  echo -e "${BOLD}Services (user: ${TC_USER}):${NC}"
  for svc in "$SVC_BRIDGE" "$SVC_SUPREME"; do
    if $SCTL is-active "$svc" &>/dev/null; then
      echo -e "  ${GREEN}●${NC} $svc (running)"
    else
      echo -e "  ${RED}●${NC} $svc (stopped)"
    fi
  done

  echo ""
  echo -e "${BOLD}Agents:${NC}"
  node -e "
    const fs = require('fs');
    const c = JSON.parse(fs.readFileSync('$SCRIPT_DIR/user/config.json','utf-8'));
    for (const [id, a] of Object.entries(c.agents)) {
      const token = a.botToken ? '✅ token set' : '❌ no token';
      const model = a.model || c.defaults?.model || 'claude-sonnet-4-6';
      console.log('  ' + id.padEnd(18) + token.padEnd(16) + model);
    }
  " 2>/dev/null || warn "Could not read config"

  echo ""

  # Check gateway
  local gw_token
  gw_token=$(node -e "console.log(JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/user/config.json','utf-8')).gateway.auth.token)" 2>/dev/null || echo "")
  if [ -n "$gw_token" ]; then
    local health
    local gw_port
    gw_port=$(get_gateway_port)
    health=$(curl -s -H "Authorization: Bearer $gw_token" "http://127.0.0.1:${gw_port}/api/health" 2>/dev/null || echo "")
    if [ -n "$health" ] && echo "$health" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const h=JSON.parse(d);console.log('Gateway: ✅ up | Uptime: '+Math.floor(h.uptime)+'s | Active bots: '+(h.activeBots||0))})" 2>/dev/null; then
      :
    else
      echo "  Gateway: not responding (bridge may be down)"
    fi
  fi
}

