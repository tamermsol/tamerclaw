#!/usr/bin/env bash
# TamerClaw CLI v1.0
# Multi-agent Claude Code system with Telegram bridge
#
# Usage: tamerclaw <command> [args]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export TAMERCLAW_HOME="$SCRIPT_DIR"
VERSION=$(node -e "console.log(JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/version.json','utf-8')).version)" 2>/dev/null || echo "1.0.0")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

banner() {
  echo -e "${CYAN}"
  echo '  ╔═══════════════════════════════════════╗'
  echo '  ║         TamerClaw v'"$VERSION"'              ║'
  echo '  ║   Multi-Agent Claude Code System      ║'
  echo '  ╚═══════════════════════════════════════╝'
  echo -e "${NC}"
}

info()  { echo -e "${GREEN}[✓]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[✗]${NC} $*"; }
ask()   { echo -en "${CYAN}[?]${NC} $* "; }

# ── Prerequisites Check ──────────────────────────────────────────────────────
check_prereqs() {
  local missing=0

  if ! command -v node &>/dev/null; then
    err "Node.js not found. Install Node.js 18+ first."
    missing=1
  else
    local node_ver
    node_ver=$(node -v | sed 's/v//' | cut -d. -f1)
    if [ "$node_ver" -lt 18 ]; then
      err "Node.js $node_ver found but 18+ required."
      missing=1
    fi
  fi

  if ! command -v claude &>/dev/null; then
    err "Claude Code CLI not found."
    echo "    Install: npm install -g @anthropic-ai/claude-code"
    echo "    Or: curl -fsSL https://claude.ai/install.sh | sh"
    missing=1
  fi

  if [ "$missing" -eq 1 ]; then
    echo ""
    err "Missing prerequisites. Install them and try again."
    exit 1
  fi

  info "Prerequisites OK (Node.js $(node -v), Claude CLI found)"
}

# ── Claude Code Auth Check ────────────────────────────────────────────────────
check_claude_auth() {
  echo ""
  info "Checking Claude Code authentication..."

  # Test if claude is authenticated by running a simple command
  local auth_test
  auth_test=$(echo "respond with just OK" | claude -p --output-format text 2>&1) || true

  if echo "$auth_test" | grep -qi "OK"; then
    info "Claude Code is authenticated and working"
    return 0
  fi

  # Not authenticated — guide the user
  warn "Claude Code is not authenticated yet."
  echo ""
  echo -e "  ${BOLD}You need to log in to Claude Code first.${NC}"
  echo ""
  echo "  Run this command in a separate terminal:"
  echo ""
  echo -e "    ${CYAN}claude${NC}"
  echo ""
  echo "  This will open a browser for authentication."
  echo "  Once logged in, come back here and continue."
  echo ""
  ask "Press Enter when you've logged in to Claude Code (or 'skip' to continue without):"
  read -r auth_response

  if [ "$auth_response" = "skip" ]; then
    warn "Skipping auth check. Agents won't work until Claude Code is authenticated."
    return 0
  fi

  # Re-test
  auth_test=$(echo "respond with just OK" | claude -p --output-format text 2>&1) || true
  if echo "$auth_test" | grep -qi "OK"; then
    info "Claude Code is authenticated and working"
  else
    warn "Claude Code still not responding. Check authentication and try again."
    warn "Continuing setup — you can fix auth later."
  fi
}

# ── Detect claude binary path for systemd ─────────────────────────────────────
get_claude_path() {
  local claude_bin
  claude_bin=$(which claude 2>/dev/null || echo "")
  if [ -z "$claude_bin" ]; then
    # Common locations
    for p in "$HOME/.local/bin/claude" "/usr/local/bin/claude" "/usr/bin/claude"; do
      if [ -x "$p" ]; then
        claude_bin="$p"
        break
      fi
    done
  fi
  echo "$claude_bin"
}

# ── Agent Scanner ─────────────────────────────────────────────────────────────
# Scans the user's system for existing Claude Code agent directories.
# Looks for: CLAUDE.md, IDENTITY.md, .claude/ dirs in common locations.
scan_agents() {
  local found=()
  local search_dirs=("$HOME")

  # Add /root if not already HOME
  [ "$HOME" != "/root" ] && [ -d "/root" ] && search_dirs+=("/root")

  # Check for existing claude-agents setups
  for base in "$HOME" "/root"; do
    [ -d "$base/claude-agents/agents" ] && search_dirs+=("$base/claude-agents/agents")
  done

  echo ""
  info "Scanning for existing Claude Code agents..."
  echo ""

  # Strategy 1: Look for directories with IDENTITY.md (strong signal)
  for dir in "${search_dirs[@]}"; do
    [ -d "$dir" ] || continue
    while IFS= read -r identity_file; do
      local agent_dir
      agent_dir=$(dirname "$identity_file")
      # Skip if it's inside tamerclaw itself
      [[ "$agent_dir" == *"tamerclaw"* ]] && continue
      found+=("$agent_dir")
    done < <(find "$dir" -maxdepth 4 -name "IDENTITY.md" -type f 2>/dev/null | head -20)
  done

  # Strategy 2: Look for directories with CLAUDE.md (Claude Code projects)
  for dir in "${search_dirs[@]}"; do
    [ -d "$dir" ] || continue
    while IFS= read -r claude_file; do
      local project_dir
      project_dir=$(dirname "$claude_file")
      [[ "$project_dir" == *"tamerclaw"* ]] && continue
      # Only add if not already found
      local already=0
      for f in "${found[@]+"${found[@]}"}"; do
        [ "$f" = "$project_dir" ] && already=1 && break
      done
      [ "$already" -eq 0 ] && found+=("$project_dir")
    done < <(find "$dir" -maxdepth 3 -name "CLAUDE.md" -type f 2>/dev/null | head -20)
  done

  # Deduplicate
  local unique=()
  declare -A seen
  for f in "${found[@]+"${found[@]}"}"; do
    if [ -z "${seen[$f]+x}" ]; then
      seen[$f]=1
      unique+=("$f")
    fi
  done

  if [ ${#unique[@]} -eq 0 ]; then
    warn "No existing agents found."
    echo "    You can add agents later with: tamerclaw add-agent"
    echo ""
    FOUND_AGENTS=()
    return
  fi

  echo "  Found ${#unique[@]} potential agent(s):"
  echo ""
  for i in "${!unique[@]}"; do
    local dir="${unique[$i]}"
    local name
    name=$(basename "$dir")
    local desc=""
    # Try to read first line of IDENTITY.md for description
    if [ -f "$dir/IDENTITY.md" ]; then
      desc=$(head -3 "$dir/IDENTITY.md" | grep -v '^#' | grep -v '^$' | head -1 | cut -c1-60)
    elif [ -f "$dir/CLAUDE.md" ]; then
      desc=$(head -3 "$dir/CLAUDE.md" | grep -v '^#' | grep -v '^$' | head -1 | cut -c1-60)
    fi
    printf "  ${BOLD}[%d]${NC} %-20s %s\n" "$((i+1))" "$name" "${desc:-(no description)}"
    printf "      ${CYAN}%s${NC}\n" "$dir"
  done
  echo ""

  FOUND_AGENTS=("${unique[@]}")
}

# ── Init Command ──────────────────────────────────────────────────────────────
cmd_init() {
  banner

  # Check if already initialized
  if [ -f "$SCRIPT_DIR/user/config.json" ]; then
    warn "TamerClaw is already initialized."
    ask "Reinitialize? This will overwrite your config. (y/N):"
    read -r reinit
    if [[ ! "$reinit" =~ ^[Yy] ]]; then
      echo "Aborted."
      exit 0
    fi
  fi

  check_prereqs
  check_claude_auth

  echo ""
  echo -e "${BOLD}Let's set up your TamerClaw system.${NC}"
  echo ""

  # ── Step 1: User info ──
  ask "What's your name?"
  read -r user_name
  [ -z "$user_name" ] && user_name="User"

  ask "What's your Telegram user ID? (find via @userinfobot):"
  read -r telegram_id
  if [ -z "$telegram_id" ]; then
    warn "No Telegram ID provided. You can set it later in user/credentials/"
    telegram_id=""
  fi

  # ── Step 2: Supreme Agent (FIRST — it makes everything else simpler) ──
  echo ""
  echo -e "${BOLD}═══ Supreme Agent Setup ═══${NC}"
  echo ""
  echo "The Supreme Agent is your master controller. It manages all other agents,"
  echo "fixes bugs, creates new agents, and coordinates everything — all from Telegram."
  echo ""
  echo "You need to create a Telegram bot for it:"
  echo "  1. Open @BotFather on Telegram"
  echo "  2. Send /newbot"
  echo "  3. Name it something like 'My Supreme Agent'"
  echo "  4. Copy the bot token"
  echo ""
  ask "Bot token for Supreme Agent:"
  read -r supreme_token

  if [ -z "$supreme_token" ]; then
    warn "No Supreme token. Supreme Agent won't start until you set one."
    warn "Set later with: tamerclaw set-token supreme <token>"
  else
    info "Supreme Agent token set"
  fi

  # ── Step 3: Scan for existing agents ──
  scan_agents

  # ── Step 4: Select agents to link ──
  local selected_agents=()
  local selected_paths=()

  if [ ${#FOUND_AGENTS[@]} -gt 0 ]; then
    echo "Which agents do you want to link? (comma-separated numbers, or 'all', or 'none')"
    ask "Selection:"
    read -r selection

    if [ "$selection" = "all" ]; then
      selected_agents=("${FOUND_AGENTS[@]}")
    elif [ "$selection" != "none" ] && [ -n "$selection" ]; then
      IFS=',' read -ra nums <<< "$selection"
      for num in "${nums[@]}"; do
        num=$(echo "$num" | tr -d ' ')
        local idx=$((num - 1))
        if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#FOUND_AGENTS[@]}" ]; then
          selected_agents+=("${FOUND_AGENTS[$idx]}")
        fi
      done
    fi
  fi

  # ── Step 5: Bot tokens for each selected agent ──
  echo ""
  if [ ${#selected_agents[@]} -gt 0 ]; then
    echo -e "${BOLD}═══ Agent Telegram Setup ═══${NC}"
    echo ""
    echo "Each agent needs its own Telegram bot (separate from Supreme)."
    echo "Create one bot per agent via @BotFather."
    echo ""
  fi

  declare -A agent_tokens
  for agent_path in "${selected_agents[@]+"${selected_agents[@]}"}"; do
    local agent_name
    agent_name=$(basename "$agent_path")
    ask "Bot token for '${agent_name}' (or press Enter to skip):"
    read -r token
    if [ -n "$token" ]; then
      agent_tokens[$agent_name]="$token"
    else
      warn "Skipped $agent_name — you can add token later with: tamerclaw set-token $agent_name <token>"
    fi
  done

  # ── Step 6: Generate config ──
  info "Generating configuration..."

  # Create user directories
  mkdir -p "$SCRIPT_DIR/user/agents/supreme/memory"
  mkdir -p "$SCRIPT_DIR/user/agents/supreme/sessions"
  mkdir -p "$SCRIPT_DIR/user/agents/supreme/media"
  mkdir -p "$SCRIPT_DIR/user/credentials"
  mkdir -p "$SCRIPT_DIR/user/logs"
  mkdir -p "$SCRIPT_DIR/user/delivery-queue/pending"
  mkdir -p "$SCRIPT_DIR/user/delivery-queue/failed"
  mkdir -p "$SCRIPT_DIR/user/cron/runs"

  # Generate gateway auth token
  local gw_token
  gw_token=$(node -e "console.log(require('crypto').randomBytes(24).toString('hex'))")

  # Build agents JSON
  local agents_json='{'

  # Add selected agents
  for agent_path in "${selected_agents[@]+"${selected_agents[@]}"}"; do
    local agent_name
    agent_name=$(basename "$agent_path")
    local token="${agent_tokens[$agent_name]:-}"

    # Create agent directory in user/
    mkdir -p "$SCRIPT_DIR/user/agents/$agent_name/memory"
    mkdir -p "$SCRIPT_DIR/user/agents/$agent_name/sessions"
    mkdir -p "$SCRIPT_DIR/user/agents/$agent_name/media"

    # Copy identity files if they exist
    for f in IDENTITY.md USER.md TOOLS.md MEMORY.md; do
      if [ -f "$agent_path/$f" ]; then
        cp "$agent_path/$f" "$SCRIPT_DIR/user/agents/$agent_name/$f"
      fi
    done

    # Create USER.md if it doesn't exist
    if [ ! -f "$SCRIPT_DIR/user/agents/$agent_name/USER.md" ]; then
      cat > "$SCRIPT_DIR/user/agents/$agent_name/USER.md" << USEREOF
# User Profile

- **Name:** $user_name
- **Telegram ID:** ${telegram_id:-not set}
USEREOF
    fi

    # Store workspace path (the original location)
    agents_json+="\"$agent_name\":{\"botToken\":\"$token\",\"workspace\":\"$agent_path\",\"identity\":\"$SCRIPT_DIR/user/agents/$agent_name/IDENTITY.md\"},"
  done

  # Add supreme agent
  agents_json+="\"supreme\":{\"botToken\":\"${supreme_token:-}\",\"model\":\"claude-opus-4-6\",\"standalone\":true,\"standalonePath\":\"$SCRIPT_DIR/core/supreme/bot.js\"}"
  agents_json+='}'

  # Create Supreme Agent identity
  cat > "$SCRIPT_DIR/user/agents/supreme/IDENTITY.md" << 'SUPEOF'
# Supreme Agent

You are the **Supreme Agent** — the master controller of the TamerClaw multi-agent ecosystem.

## Your Role
- Manage, monitor, and coordinate all agents in the system
- Fix bugs, update configurations, and create new agents
- Serve as the primary interface for system administration
- Ensure all agents are running correctly and efficiently

## Personality
- Authoritative but helpful
- Proactive about system health
- Clear and concise in status reports
- Takes initiative on maintenance tasks
SUPEOF

  # Create Supreme USER.md
  cat > "$SCRIPT_DIR/user/agents/supreme/USER.md" << SUPUSEREOF
# User Profile

- **Name:** $user_name
- **Telegram ID:** ${telegram_id:-not set}
- **Role:** System administrator
SUPUSEREOF

  # Create Supreme TOOLS.md
  cat > "$SCRIPT_DIR/user/agents/supreme/TOOLS.md" << 'SUPTOOLSEOF'
# Supreme Agent Tools

## System Access
- Full read/write to TamerClaw directory
- Can run shell commands
- Can modify config.json (always backup first)
- Can create/modify/delete agents
- Can restart bridge service

## Self-Protection
- NEVER restart supreme-agent service
- NEVER edit supreme/bot.js
- NEVER kill your own process
SUPTOOLSEOF

  # Write config.json
  node -e "
    const config = {
      version: 2,
      system: {
        name: 'tamerclaw',
        description: 'Multi-agent Claude Code system with Telegram bridge',
        installedAt: new Date().toISOString(),
        installedBy: '$user_name'
      },
      models: {
        providers: {
          anthropic: {
            api: 'claude-cli',
            models: {
              'claude-opus-4-6': { cliFlag: 'opus', contextWindow: 200000 },
              'claude-sonnet-4-6': { cliFlag: 'sonnet', contextWindow: 200000 },
              'claude-haiku-4-5': { cliFlag: 'haiku', contextWindow: 200000 }
            }
          }
        },
        defaultProvider: 'anthropic'
      },
      defaults: {
        model: 'claude-sonnet-4-6',
        fallbackModels: ['claude-sonnet-4-6'],
        maxTokens: 16384,
        contextTokens: 131072,
        allowedTools: ['Read', 'Write', 'Edit', 'Bash', 'Glob', 'Grep', 'Agent', 'WebSearch', 'WebFetch'],
        memoryEnabled: true
      },
      telegram: {
        pollingInterval: 1000,
        maxMessageLength: 4096,
        splitLongMessages: true,
        debounceMs: 2000
      },
      gateway: {
        enabled: true,
        port: 19789,
        bind: 'loopback',
        auth: { mode: 'token', token: '$gw_token' }
      },
      cron: {
        enabled: true,
        tickIntervalMs: 30000
      },
      agents: $agents_json
    };
    require('fs').writeFileSync('$SCRIPT_DIR/user/config.json', JSON.stringify(config, null, 2));
  "

  # Create default allowlist
  if [ -n "$telegram_id" ]; then
    echo "{\"users\":[$telegram_id],\"allowAll\":false}" > "$SCRIPT_DIR/user/credentials/telegram-default-allowFrom.json"
    info "Allowlist set: only Telegram user $telegram_id can message your agents"
  else
    echo '{"allowAll":true}' > "$SCRIPT_DIR/user/credentials/telegram-default-allowFrom.json"
    warn "Allowlist: open to all (set your Telegram ID to restrict)"
  fi

  # Create empty cron jobs
  echo '{"version":1,"jobs":[]}' > "$SCRIPT_DIR/user/cron/jobs.json"

  # ── Step 7: Install dependencies ──
  info "Installing dependencies..."
  (cd "$SCRIPT_DIR/core/bridge" && npm install --silent 2>&1 | tail -1) || true
  (cd "$SCRIPT_DIR/core/supreme" && npm install --silent 2>&1 | tail -1) || true

  # ── Step 8: Create systemd services ──
  info "Setting up systemd services..."

  # Build PATH that includes claude binary location
  local claude_bin_dir
  claude_bin_dir=$(dirname "$(get_claude_path)" 2>/dev/null || echo "")
  local svc_path="$PATH"
  if [ -n "$claude_bin_dir" ] && [[ ":$svc_path:" != *":$claude_bin_dir:"* ]]; then
    svc_path="$claude_bin_dir:$svc_path"
  fi
  # Ensure common paths are included
  for p in "$HOME/.local/bin" "/usr/local/bin" "/usr/bin"; do
    [[ ":$svc_path:" != *":$p:"* ]] && svc_path="$p:$svc_path"
  done

  cat > /etc/systemd/system/tamerclaw-bridge.service << SVCEOF
[Unit]
Description=TamerClaw Bridge (Telegram ↔ Claude Code)
After=network.target

[Service]
Type=simple
WorkingDirectory=$SCRIPT_DIR/core/bridge
ExecStart=$(which node) index.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production
Environment=TAMERCLAW_HOME=$SCRIPT_DIR
Environment=HOME=$HOME
Environment=PATH=$svc_path
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tamerclaw-bridge

[Install]
WantedBy=multi-user.target
SVCEOF

  cat > /etc/systemd/system/tamerclaw-supreme.service << SVCEOF
[Unit]
Description=TamerClaw Supreme Agent
After=network.target

[Service]
Type=simple
WorkingDirectory=$SCRIPT_DIR/core/supreme
ExecStart=$(which node) bot.js
ExecStartPre=/bin/bash -c 'pkill -f "node.*tamerclaw.*supreme/bot.js" 2>/dev/null || true; sleep 1'
Restart=always
RestartSec=10
Environment=NODE_ENV=production
Environment=TAMERCLAW_HOME=$SCRIPT_DIR
Environment=HOME=$HOME
Environment=PATH=$svc_path
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tamerclaw-supreme

[Install]
WantedBy=multi-user.target
SVCEOF

  systemctl daemon-reload 2>/dev/null || true
  systemctl enable tamerclaw-bridge tamerclaw-supreme 2>/dev/null || true

  # ── Done! ──
  echo ""
  echo -e "${GREEN}═══════════════════════════════════════════${NC}"
  echo -e "${GREEN}  TamerClaw initialized successfully!${NC}"
  echo -e "${GREEN}═══════════════════════════════════════════${NC}"
  echo ""
  echo "  Config:    $SCRIPT_DIR/user/config.json"
  echo "  Agents:    $SCRIPT_DIR/user/agents/"
  echo ""

  local agent_count=0
  for agent_path in "${selected_agents[@]+"${selected_agents[@]}"}"; do
    agent_count=$((agent_count + 1))
  done

  echo "  Linked agents: $agent_count"
  [ -n "$supreme_token" ] && echo "  Supreme Agent: ready" || echo "  Supreme Agent: needs token"
  echo ""
  echo "  Next steps:"
  echo "    tamerclaw start         # Start all services"
  echo "    tamerclaw status        # Check status"
  echo "    tamerclaw logs          # View logs"
  echo ""
  if [ "$agent_count" -eq 0 ] && [ -z "$supreme_token" ]; then
    echo "  Set tokens first:"
    echo "    tamerclaw set-token supreme <bot-token>"
    echo ""
  fi
}

# ── Update Command ────────────────────────────────────────────────────────────
cmd_update() {
  banner

  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  info "Checking for updates..."

  # Check if we're in a git repo
  if [ ! -d "$SCRIPT_DIR/.git" ]; then
    err "Not a git repository. Updates require git."
    echo "    If you installed manually, re-clone the repo and copy your user/ directory."
    exit 1
  fi

  # Stash any local changes to core
  local stashed=0
  if ! git -C "$SCRIPT_DIR" diff --quiet -- core/; then
    warn "Local changes in core/ detected. Stashing..."
    git -C "$SCRIPT_DIR" stash push -m "tamerclaw-update-$(date +%s)" -- core/ 2>/dev/null
    stashed=1
  fi

  # Pull latest
  local old_version="$VERSION"
  git -C "$SCRIPT_DIR" pull --ff-only origin main 2>&1 || {
    err "Pull failed. You may have diverged from upstream."
    echo "    Try: cd $SCRIPT_DIR && git pull --rebase origin main"
    [ "$stashed" -eq 1 ] && git -C "$SCRIPT_DIR" stash pop 2>/dev/null
    exit 1
  }

  local new_version
  new_version=$(node -e "console.log(JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/version.json','utf-8')).version)" 2>/dev/null || echo "unknown")

  # Reinstall deps if package.json changed
  if git -C "$SCRIPT_DIR" diff HEAD~1 --name-only 2>/dev/null | grep -q "package.json"; then
    info "Dependencies changed. Reinstalling..."
    (cd "$SCRIPT_DIR/core/bridge" && npm install --silent) || true
    (cd "$SCRIPT_DIR/core/supreme" && npm install --silent) || true
  fi

  # Reload systemd if service files changed
  systemctl daemon-reload 2>/dev/null || true

  # Restart services if running
  if systemctl is-active tamerclaw-bridge &>/dev/null; then
    info "Restarting bridge..."
    systemctl restart tamerclaw-bridge
  fi
  if systemctl is-active tamerclaw-supreme &>/dev/null; then
    info "Restarting Supreme Agent..."
    systemctl restart tamerclaw-supreme
  fi

  echo ""
  if [ "$old_version" != "$new_version" ]; then
    info "Updated: v${old_version} → v${new_version}"
  else
    info "Already up to date (v${VERSION})"
  fi
}

# ── Start/Stop/Restart ────────────────────────────────────────────────────────
cmd_start() {
  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  local target="${1:-all}"

  case "$target" in
    bridge)
      systemctl start tamerclaw-bridge
      info "Bridge started. Logs: journalctl -u tamerclaw-bridge -f"
      ;;
    supreme)
      systemctl start tamerclaw-supreme
      info "Supreme Agent started. Logs: journalctl -u tamerclaw-supreme -f"
      ;;
    all|"")
      systemctl start tamerclaw-bridge 2>/dev/null && info "Bridge started" || warn "Bridge failed to start"
      systemctl start tamerclaw-supreme 2>/dev/null && info "Supreme Agent started" || warn "Supreme failed to start"
      echo ""
      info "All services started. Logs: tamerclaw logs"
      ;;
    --foreground)
      info "Starting bridge in foreground..."
      cd "$SCRIPT_DIR/core/bridge" && TAMERCLAW_HOME="$SCRIPT_DIR" node index.js
      ;;
    *)
      err "Unknown target: $target"
      echo "Usage: tamerclaw start [bridge|supreme|all|--foreground]"
      ;;
  esac
}

cmd_stop() {
  local target="${1:-all}"
  case "$target" in
    bridge)  systemctl stop tamerclaw-bridge; info "Bridge stopped" ;;
    supreme) systemctl stop tamerclaw-supreme; info "Supreme stopped" ;;
    all|"")
      systemctl stop tamerclaw-bridge 2>/dev/null; systemctl stop tamerclaw-supreme 2>/dev/null
      info "All services stopped"
      ;;
  esac
}

cmd_restart() {
  local target="${1:-all}"
  case "$target" in
    bridge)  systemctl restart tamerclaw-bridge; info "Bridge restarted" ;;
    supreme) systemctl restart tamerclaw-supreme; info "Supreme restarted" ;;
    all|"")
      systemctl restart tamerclaw-bridge 2>/dev/null; systemctl restart tamerclaw-supreme 2>/dev/null
      info "All services restarted"
      ;;
  esac
}

# ── Status ────────────────────────────────────────────────────────────────────
cmd_status() {
  banner

  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  echo -e "${BOLD}Services:${NC}"
  for svc in tamerclaw-bridge tamerclaw-supreme; do
    if systemctl is-active "$svc" &>/dev/null; then
      echo -e "  ${GREEN}●${NC} $svc (running)"
    else
      echo -e "  ${RED}●${NC} $svc (stopped)"
    fi
  done

  echo ""
  echo -e "${BOLD}Agents:${NC}"
  node -e "
    const fs = require('fs');
    const c = JSON.parse(fs.readFileSync('$SCRIPT_DIR/user/config.json','utf-8'));
    for (const [id, a] of Object.entries(c.agents)) {
      const token = a.botToken ? '✅ token set' : '❌ no token';
      const model = a.model || c.defaults?.model || 'claude-sonnet-4-6';
      console.log('  ' + id.padEnd(18) + token.padEnd(16) + model);
    }
  " 2>/dev/null || warn "Could not read config"

  echo ""

  # Check gateway
  local gw_token
  gw_token=$(node -e "console.log(JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/user/config.json','utf-8')).gateway.auth.token)" 2>/dev/null || echo "")
  if [ -n "$gw_token" ]; then
    local health
    health=$(curl -s -H "Authorization: Bearer $gw_token" http://127.0.0.1:19789/api/health 2>/dev/null || echo "")
    if [ -n "$health" ] && echo "$health" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const h=JSON.parse(d);console.log('Gateway: ✅ up | Uptime: '+Math.floor(h.uptime)+'s | Active bots: '+(h.activeBots||0))})" 2>/dev/null; then
      :
    else
      echo "  Gateway: not responding (bridge may be down)"
    fi
  fi
}

# ── Logs ──────────────────────────────────────────────────────────────────────
cmd_logs() {
  local target="${1:-all}"
  case "$target" in
    bridge)  journalctl -u tamerclaw-bridge -f --no-pager ;;
    supreme) journalctl -u tamerclaw-supreme -f --no-pager ;;
    all|"")  journalctl -u tamerclaw-bridge -u tamerclaw-supreme -f --no-pager ;;
  esac
}

# ── Agent Management ──────────────────────────────────────────────────────────
cmd_set_token() {
  local agent_id="$1"
  local token="$2"

  if [ -z "$agent_id" ] || [ -z "$token" ]; then
    err "Usage: tamerclaw set-token <agentId> <botToken>"
    exit 1
  fi

  node -e "
    const fs = require('fs');
    const configPath = '$SCRIPT_DIR/user/config.json';
    const c = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
    if (!c.agents['$agent_id']) {
      console.error('Agent not found: $agent_id');
      process.exit(1);
    }
    c.agents['$agent_id'].botToken = '$token';
    fs.writeFileSync(configPath, JSON.stringify(c, null, 2));
    console.log('✅ Token set for $agent_id');
  "
}

cmd_agents() {
  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  echo -e "${BOLD}Configured agents:${NC}"
  echo ""
  node -e "
    const fs = require('fs');
    const c = JSON.parse(fs.readFileSync('$SCRIPT_DIR/user/config.json','utf-8'));
    for (const [id, a] of Object.entries(c.agents)) {
      const token = a.botToken ? '✅ token set' : '❌ no token';
      const model = a.model || c.defaults?.model || 'claude-sonnet-4-6';
      const ws = a.workspace || a.standalonePath || '(supreme)';
      console.log('  ' + id.padEnd(18) + token.padEnd(16) + model);
      if (ws) console.log('    ' + ws);
    }
  " 2>/dev/null
}

cmd_test() {
  local target="${1:---all}"
  cd "$SCRIPT_DIR/core/bridge" && TAMERCLAW_HOME="$SCRIPT_DIR" node test-connection.js "$target"
}

cmd_test_claude() {
  info "Testing Claude CLI..."
  echo "Hello, respond with just 'OK' if you can hear me." | claude -p --output-format text 2>&1
}

# ── Manage.sh compatibility commands ──────────────────────────────────────────
cmd_send() {
  local agent_id="$1"
  local message="$2"
  if [ -z "$agent_id" ] || [ -z "$message" ]; then
    err "Usage: tamerclaw send <agentId> '<message>'"
    exit 1
  fi
  local gw_token
  gw_token=$(node -e "console.log(JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/user/config.json','utf-8')).gateway.auth.token)" 2>/dev/null)
  curl -s -X POST -H "Authorization: Bearer $gw_token" -H "Content-Type: application/json" \
    -d "{\"message\":\"$message\"}" \
    "http://127.0.0.1:19789/api/agents/$agent_id/message" | node -e "
    let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
      try { console.log(JSON.parse(d).response || d); } catch { console.log(d); }
    })
  "
}

cmd_cron_list() {
  node -e "
    const fs = require('fs');
    const d = JSON.parse(fs.readFileSync('$SCRIPT_DIR/user/cron/jobs.json','utf-8'));
    if (d.jobs.length === 0) { console.log('No cron jobs.'); process.exit(0); }
    for (const j of d.jobs) {
      const sched = j.schedule.kind === 'at' ? 'at ' + j.schedule.at : j.schedule.cron;
      const status = j.enabled ? '✅' : '❌';
      console.log(status + ' ' + j.name.padEnd(30) + j.agentId.padEnd(12) + sched);
    }
  " 2>/dev/null
}

# ── Add Agent ─────────────────────────────────────────────────────────────────
cmd_add_agent() {
  local agent_id="$1"
  local agent_path="$2"

  if [ -z "$agent_id" ]; then
    err "Usage: tamerclaw add-agent <name> [path-to-existing-agent-dir]"
    exit 1
  fi

  mkdir -p "$SCRIPT_DIR/user/agents/$agent_id/memory"
  mkdir -p "$SCRIPT_DIR/user/agents/$agent_id/sessions"
  mkdir -p "$SCRIPT_DIR/user/agents/$agent_id/media"

  # Copy files from existing agent dir if provided
  if [ -n "$agent_path" ] && [ -d "$agent_path" ]; then
    for f in IDENTITY.md USER.md TOOLS.md MEMORY.md; do
      [ -f "$agent_path/$f" ] && cp "$agent_path/$f" "$SCRIPT_DIR/user/agents/$agent_id/$f"
    done
    info "Copied agent files from $agent_path"
  fi

  # Create skeleton IDENTITY.md if not exists
  if [ ! -f "$SCRIPT_DIR/user/agents/$agent_id/IDENTITY.md" ]; then
    cat > "$SCRIPT_DIR/user/agents/$agent_id/IDENTITY.md" << EOF
# $agent_id Agent

A Claude Code agent managed by TamerClaw.
EOF
  fi

  # Add to config
  node -e "
    const fs = require('fs');
    const configPath = '$SCRIPT_DIR/user/config.json';
    const c = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
    if (c.agents['$agent_id']) {
      console.error('Agent already exists: $agent_id');
      process.exit(1);
    }
    c.agents['$agent_id'] = {
      botToken: '',
      workspace: '${agent_path:-}',
      identity: '$SCRIPT_DIR/user/agents/$agent_id/IDENTITY.md'
    };
    fs.writeFileSync(configPath, JSON.stringify(c, null, 2));
    console.log('✅ Agent added: $agent_id');
    console.log('Set token: tamerclaw set-token $agent_id <bot-token>');
  "
}

# ── Main Dispatch ─────────────────────────────────────────────────────────────
case "${1:-}" in
  init)       cmd_init ;;
  update)     cmd_update ;;
  start)      cmd_start "${2:-}" ;;
  stop)       cmd_stop "${2:-}" ;;
  restart)    cmd_restart "${2:-}" ;;
  status)     cmd_status ;;
  logs)       cmd_logs "${2:-}" ;;
  set-token)  cmd_set_token "${2:-}" "${3:-}" ;;
  agents)     cmd_agents ;;
  test)       cmd_test "${2:-}" ;;
  test-claude) cmd_test_claude ;;
  send)       cmd_send "${2:-}" "${3:-}" ;;
  cron-list)  cmd_cron_list ;;
  add-agent)  cmd_add_agent "${2:-}" "${3:-}" ;;
  version|-v|--version)
    echo "TamerClaw v${VERSION}"
    ;;
  help|-h|--help|"")
    banner
    echo "Commands:"
    echo ""
    echo "  ${BOLD}Setup:${NC}"
    echo "    init                   Initialize TamerClaw (interactive wizard)"
    echo "    update                 Pull latest updates and restart services"
    echo ""
    echo "  ${BOLD}Services:${NC}"
    echo "    start [target]         Start services (bridge|supreme|all|--foreground)"
    echo "    stop [target]          Stop services"
    echo "    restart [target]       Restart services"
    echo "    status                 Show system status"
    echo "    logs [target]          Tail logs (bridge|supreme|all)"
    echo ""
    echo "  ${BOLD}Agents:${NC}"
    echo "    agents                 List all agents"
    echo "    add-agent NAME [PATH]  Add a new agent"
    echo "    set-token ID TOKEN     Set Telegram bot token"
    echo "    test [ID|--all]        Test Telegram connections"
    echo "    test-claude            Verify Claude CLI works"
    echo "    send ID 'message'      Send message to agent"
    echo ""
    echo "  ${BOLD}Cron:${NC}"
    echo "    cron-list              List scheduled jobs"
    echo ""
    echo "  ${BOLD}Other:${NC}"
    echo "    version                Show version"
    echo "    help                   Show this help"
    echo ""
    ;;
  *)
    err "Unknown command: $1"
    echo "Run 'tamerclaw help' for usage."
    exit 1
    ;;
esac
