        ;;
      presentations|digital-marketing)
        team_role="member"
        team_id="marketing"
        reports_to="cmo"
        ;;
      *)
        team_role="member"
        team_id="engineering"
        reports_to="cto"
        ;;
    esac

    if [ "$team_role" = "leader" ]; then
      local members_json=""
      case "$aid" in
        cto) members_json='"flutter", "frontend", "backend", "designer", "qa"' ;;
        cmo) members_json='"presentations", "digital-marketing"' ;;
      esac
      cat > "$SCRIPT_DIR/user/agents/$aid/config.json" << CFGEOF
{
  "team": {
    "role": "leader",
    "teamId": "$team_id",
    "members": [$members_json]
  },
  "plugins": ["code-review", "security-guidance", "code-simplifier"],
  "streaming": true,
  "systemPromptFiles": ["IDENTITY.md", "USER.md", "TOOLS.md"]
}
CFGEOF
    else
      cat > "$SCRIPT_DIR/user/agents/$aid/config.json" << CFGEOF
{
  "team": {
    "role": "member",
    "teamId": "$team_id",
    "reportsTo": "$reports_to"
  },
  "plugins": ["code-review", "security-guidance", "code-simplifier"],
  "streaming": true,
  "systemPromptFiles": ["IDENTITY.md", "USER.md", "TOOLS.md"]
}
CFGEOF
    fi

    info "Created agent: ${agent_display_names[$aid]} ($aid)"
  done

  # ── Update main config.json with all agents and teams ──
  info "Updating config.json with agency structure..."

  # Write tokens to a temp file so Node can read them safely
  local token_tmp="$SCRIPT_DIR/user/tmp/.powerup-tokens.json"
  echo "{" > "$token_tmp"
  local first_token=true
  for k in "${!agent_tokens[@]}"; do
    if $first_token; then
      first_token=false
    else
      echo "," >> "$token_tmp"
    fi
    # Escape the token value for JSON
    local escaped_val
    escaped_val=$(echo -n "${agent_tokens[$k]}" | sed 's/\\/\\\\/g; s/"/\\"/g')
    echo -n "  \"$k\": \"$escaped_val\"" >> "$token_tmp"
  done
  echo "" >> "$token_tmp"
  echo "}" >> "$token_tmp"

  node -e "
    const fs = require('fs');
    const configPath = '$SCRIPT_DIR/user/config.json';
    const c = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
    const tokens = JSON.parse(fs.readFileSync('$token_tmp', 'utf-8'));

    const agentDefs = {
      cto:                { complexPatterns: ['debug','fix','refactor','implement','create','design','architect','plan','analyze','review','delegate','coordinate'] },
      flutter:            { complexPatterns: ['debug','fix','refactor','implement','create','design','architect','plan','analyze','build','widget','layout'] },
      frontend:           { complexPatterns: ['debug','fix','refactor','implement','create','design','architect','plan','analyze','component','layout','style'] },
      backend:            { complexPatterns: ['debug','fix','refactor','implement','create','design','architect','plan','analyze','api','database','migration'] },
      designer:           { complexPatterns: ['design','architect','plan','analyze','review','layout','typography','color','spacing','prototype'] },
      qa:                 { complexPatterns: ['debug','analyze','review','test','investigate','regression','validate','compare'] },
      cmo:                { complexPatterns: ['plan','strategy','analyze','review','research','campaign','content','brand','delegate','coordinate'] },
      presentations:      { complexPatterns: ['design','create','plan','analyze','pitch','deck','story','narrative'] },
      'digital-marketing':{ complexPatterns: ['plan','strategy','analyze','research','seo','campaign','content','audit','keyword'] }
    };

    const agentIds = ['cto','flutter','frontend','backend','designer','qa','cmo','presentations','digital-marketing'];
    c.agents = c.agents || {};

    for (const aid of agentIds) {
      const def = agentDefs[aid] || {};
      const existing = c.agents[aid] || {};
      c.agents[aid] = {
        botToken: tokens[aid] || existing.botToken || '',
        model: 'dynamic',
        modelRouting: {
          complex: 'claude-opus-4-6',
          default: 'claude-sonnet-4-6',
          complexPatterns: def.complexPatterns || []
        },
        workspace: existing.workspace || '',
        identity: '$SCRIPT_DIR/user/agents/' + aid + '/IDENTITY.md'
      };
    }

    c.teams = {
      engineering: {
        name: 'Engineering',
        leader: 'cto',
        members: ['cto', 'flutter', 'frontend', 'backend', 'designer', 'qa']
      },
      marketing: {
        name: 'Marketing',
        leader: 'cmo',
        members: ['cmo', 'presentations', 'digital-marketing']
      }
    };

    fs.writeFileSync(configPath, JSON.stringify(c, null, 2));
    console.log('Config updated with ' + agentIds.length + ' agents and 2 teams');
  "

  # Clean up temp token file
  rm -f "$token_tmp"

  # ── Create team task directories ──
  mkdir -p "$SCRIPT_DIR/user/tasks/pending"
  mkdir -p "$SCRIPT_DIR/user/tasks/active"
  mkdir -p "$SCRIPT_DIR/user/tasks/completed"
  mkdir -p "$SCRIPT_DIR/user/tasks/failed"

  # ── Summary ──
  echo ""
  echo -e "${GREEN}═══════════════════════════════════════════${NC}"
  echo -e "${GREEN}  🚀 Agency Powerup Complete!${NC}"
  echo -e "${GREEN}═══════════════════════════════════════════${NC}"
  echo ""
  echo "  Agency structure:"
  echo ""
  echo -e "  ${BOLD}Engineering Team${NC} (led by CTO)"
  for aid in cto flutter frontend backend designer qa; do
    local token="${agent_tokens[$aid]:-}"
    if [ -n "$token" ]; then
      echo -e "    ${GREEN}✓${NC} ${agent_display_names[$aid]} — ready"
    else
      echo -e "    ${YELLOW}○${NC} ${agent_display_names[$aid]} — needs token"
    fi
  done
  echo ""
  echo -e "  ${BOLD}Marketing Team${NC} (led by CMO)"
  for aid in cmo presentations digital-marketing; do
    local token="${agent_tokens[$aid]:-}"
    if [ -n "$token" ]; then
      echo -e "    ${GREEN}✓${NC} ${agent_display_names[$aid]} — ready"
    else
      echo -e "    ${YELLOW}○${NC} ${agent_display_names[$aid]} — needs token"
    fi
  done
  echo ""

  if [ "$skipped_count" -gt 0 ]; then
    echo "  Set missing tokens with:"
    echo "    tamerclaw set-token <agent-id> <bot-token>"
    echo ""
    echo "  Agent IDs: cto, flutter, frontend, backend, designer, qa, cmo, presentations, digital-marketing"
    echo ""
  fi

  echo "  Next steps:"
  echo "    tamerclaw restart all    # Restart to load new agents"
  echo "    tamerclaw agents         # List all agents"
  echo "    tamerclaw status         # Check system status"
  echo ""
}

# ── Main Dispatch ─────────────────────────────────────────────────────────────
case "${1:-}" in
  init)       cmd_init ;;
  powerup)    cmd_powerup ;;
  update)     cmd_update ;;
  start)      cmd_start "${2:-}" "${3:-}" ;;
  stop)       cmd_stop "${2:-}" ;;
  restart|safe-restart)    cmd_restart "${2:-}" ;;
  status)     cmd_status ;;
  doctor)     cmd_doctor ;;
  repair)     cmd_repair ;;
  migrate)    migrate_old_services ;;
  logs)       cmd_logs "${2:-}" ;;
  set-token)  cmd_set_token "${2:-}" "${3:-}" ;;
  agents)     cmd_agents ;;
  test)       cmd_test "${2:-}" ;;
  test-claude) cmd_test_claude ;;
  send)       cmd_send "${2:-}" "${3:-}" ;;
  cron-list)  cmd_cron_list ;;
  add-agent)  cmd_add_agent "${2:-}" "${3:-}" ;;
  allow-all)  cmd_allow_all ;;
  restrict)   cmd_restrict "${2:-}" ;;
  version|-v|--version)
    echo "TamerClaw v${VERSION}"
    ;;
  help|-h|--help|"")
    banner
    echo "Commands:"
    echo ""
    echo "  ${BOLD}Setup:${NC}"
    echo "    init                   Initialize TamerClaw (interactive wizard)"
    echo "    powerup                Set up full agency (CTO + CMO teams with agents)"
    echo "    update                 Pull latest updates and restart services"
    echo "    repair                 Reinstall deps + regenerate service files"
    echo ""
    echo "  ${BOLD}Services:${NC}"
    echo "    start [target]         Start services (bridge|supreme|all|--foreground [bridge|supreme])"
    echo "    stop [target]          Stop services"
    echo "    restart [target]       Safe restart with health checks (bridge|supreme|all)"
    echo "    status                 Show system status"
    echo "    doctor                 Run diagnostics (check deps, services, config)"
    echo "    logs [target]          Tail logs (bridge|supreme|all)"
    echo ""
    echo "  ${BOLD}Agents:${NC}"
    echo "    agents                 List all agents"
    echo "    add-agent NAME [PATH]  Add a new agent"
    echo "    set-token ID TOKEN     Set Telegram bot token"
    echo "    test [ID|--all]        Test Telegram connections"
    echo "    test-claude            Verify Claude CLI works"
    echo "    send ID 'message'      Send message to agent"
    echo ""
    echo "  ${BOLD}Access:${NC}"
    echo "    allow-all              Make bot public (anyone can message)"
    echo "    restrict [USER_ID]     Restrict to specific Telegram user"
    echo ""
    echo "  ${BOLD}Cron:${NC}"
    echo "    cron-list              List scheduled jobs"
    echo ""
    echo "  ${BOLD}Other:${NC}"
    echo "    version                Show version"
    echo "    help                   Show this help"
    echo ""
    ;;
  *)
    err "Unknown command: $1"
    echo "Run 'tamerclaw help' for usage."
    exit 1
    ;;
esac
