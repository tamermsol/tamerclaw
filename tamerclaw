cmd_restrict() {
  local user_id="${1:-}"
  local allow_file="$SCRIPT_DIR/user/credentials/telegram-default-allowFrom.json"
  mkdir -p "$(dirname "$allow_file")"
  if [ -z "$user_id" ]; then
    # Show current state
    if [ -f "$allow_file" ]; then
      echo "Current allowlist:"
      cat "$allow_file"
    else
      echo "No allowlist file — bot is open to all by default"
