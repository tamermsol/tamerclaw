# ── Doctor (diagnostics) ──────────────────────────────────────────────────────
cmd_doctor() {
  banner
  echo -e "${BOLD}TamerClaw Diagnostics${NC}"
  echo ""

  # Check Node.js
  local node_path
  node_path=$(which node 2>/dev/null || echo "")
  if [ -n "$node_path" ]; then
    local node_ver
    node_ver=$(node --version 2>/dev/null || echo "unknown")
    echo -e "  ${GREEN}✓${NC} Node.js: $node_ver ($node_path)"
  else
    echo -e "  ${RED}✗${NC} Node.js: NOT FOUND"
  fi

  # Check Claude CLI
  local claude_path
  claude_path=$(which claude 2>/dev/null || echo "")
  if [ -n "$claude_path" ]; then
    echo -e "  ${GREEN}✓${NC} Claude CLI: $claude_path"
  else
    echo -e "  ${RED}✗${NC} Claude CLI: NOT FOUND"
  fi

  # Check npm
  local npm_path
  npm_path=$(which npm 2>/dev/null || echo "")
  if [ -n "$npm_path" ]; then
    echo -e "  ${GREEN}✓${NC} npm: $(npm --version 2>/dev/null)"
  else
    echo -e "  ${RED}✗${NC} npm: NOT FOUND"
  fi

  echo ""

  # Check config
  if [ -f "$SCRIPT_DIR/user/config.json" ]; then
    echo -e "  ${GREEN}✓${NC} Config: $SCRIPT_DIR/user/config.json"
  else
    echo -e "  ${RED}✗${NC} Config: NOT FOUND (run: tamerclaw init)"
  fi

  # Check dependencies
  echo ""
  echo -e "${BOLD}Dependencies:${NC}"
  if [ -d "$SCRIPT_DIR/core/bridge/node_modules/node-telegram-bot-api" ]; then
    echo -e "  ${GREEN}✓${NC} Bridge: node_modules installed"
  else
    echo -e "  ${RED}✗${NC} Bridge: node_modules MISSING (run: cd core/bridge && npm install)"
  fi
  if [ -d "$SCRIPT_DIR/core/supreme/node_modules/node-telegram-bot-api" ]; then
    echo -e "  ${GREEN}✓${NC} Supreme: node_modules installed"
  else
    echo -e "  ${RED}✗${NC} Supreme: node_modules MISSING (run: cd core/supreme && npm install)"
  fi

  # Check systemd
  echo ""
  echo -e "${BOLD}Systemd ($SYSTEMD_MODE mode, user: ${TC_USER}):${NC}"
  for svc in "$SVC_BRIDGE" "$SVC_SUPREME"; do
    local svc_file="$SVC_DIR/${svc}.service"
    if [ -f "$svc_file" ]; then
      local status
      status=$($SCTL is-active "$svc" 2>/dev/null || echo "inactive")
      local failed=""
      if [ "$status" = "failed" ]; then
        failed=" — $(${SCTL} show "$svc" --property=Result --value 2>/dev/null || echo "unknown reason")"
      fi
      case "$status" in
        active)   echo -e "  ${GREEN}●${NC} $svc: running" ;;
        failed)   echo -e "  ${RED}●${NC} $svc: FAILED${failed}" ;;
        *)        echo -e "  ${YELLOW}●${NC} $svc: $status" ;;
      esac
    else
      echo -e "  ${RED}✗${NC} $svc: service file not found at $svc_file"
    fi
  done

  # Show recent errors for failed services
  echo ""
  for svc in "$SVC_BRIDGE" "$SVC_SUPREME"; do
    local status
    status=$($SCTL is-active "$svc" 2>/dev/null || echo "inactive")
    if [ "$status" = "failed" ] || [ "$status" = "inactive" ]; then
      echo -e "${BOLD}Recent logs for $svc:${NC}"
      $JCTL -u "$svc" -n 20 --no-pager 2>/dev/null || echo "  (no logs available)"
      echo ""
    fi
  done

  # Check ExecStart path in service file
  echo -e "${BOLD}Service file checks:${NC}"
  for svc in "$SVC_BRIDGE" "$SVC_SUPREME"; do
    local svc_file="$SVC_DIR/${svc}.service"
    if [ -f "$svc_file" ]; then
      local exec_start
      exec_start=$(grep "^ExecStart=" "$svc_file" 2>/dev/null | head -1)
      if [ -n "$exec_start" ]; then
        local node_bin
        node_bin=$(echo "$exec_start" | sed 's/ExecStart=//' | awk '{print $1}')
        if [ -x "$node_bin" ]; then
          echo -e "  ${GREEN}✓${NC} $svc: node binary exists ($node_bin)"
        else
          echo -e "  ${RED}✗${NC} $svc: node binary NOT FOUND at $node_bin"
          echo "    Fix: tamerclaw init (to regenerate service files)"
        fi
      fi
    fi
  done
}

# ── Repair Command ────────────────────────────────────────────────────────────
cmd_repair() {
  banner
  info "Repairing TamerClaw installation..."

  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  # Reinstall dependencies
  info "Reinstalling dependencies..."
  (cd "$SCRIPT_DIR/core/bridge" && npm install --silent 2>&1 | tail -3) || warn "Bridge npm install had issues"
  (cd "$SCRIPT_DIR/core/supreme" && npm install --silent 2>&1 | tail -3) || warn "Supreme npm install had issues"

  # Regenerate systemd service files
  info "Regenerating systemd service files..."

  local claude_bin_dir
  claude_bin_dir=$(dirname "$(get_claude_path)" 2>/dev/null || echo "")
  local svc_path="$PATH"
  if [ -n "$claude_bin_dir" ] && [[ ":$svc_path:" != *":$claude_bin_dir:"* ]]; then
    svc_path="$claude_bin_dir:$svc_path"
  fi
  for p in "$HOME/.local/bin" "/usr/local/bin" "/usr/bin"; do
    [[ ":$svc_path:" != *":$p:"* ]] && svc_path="$p:$svc_path"
  done

  local svc_user_line=""
  if [ "$SYSTEMD_MODE" = "system" ] && [ "$(id -u)" -ne 0 ]; then
    svc_user_line="User=$(whoami)
Group=$(id -gn)"
  fi

  # Migrate old services first
  migrate_old_services

  write_service_file "${SVC_BRIDGE}.service" "[Unit]
Description=TamerClaw Bridge [${TC_USER}] (Telegram ↔ Claude Code)
After=network.target

[Service]
Type=simple
${svc_user_line}
WorkingDirectory=$SCRIPT_DIR/core/bridge
ExecStart=$(which node) index.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
Environment=TAMERCLAW_HOME=$SCRIPT_DIR
Environment=HOME=$HOME
Environment=PATH=$svc_path
StandardOutput=journal
StandardError=journal
SyslogIdentifier=$SVC_BRIDGE

[Install]
WantedBy=$SVC_WANTED_BY"

  write_service_file "${SVC_SUPREME}.service" "[Unit]
Description=TamerClaw Supreme Agent [${TC_USER}]
After=network.target

[Service]
Type=simple
${svc_user_line}
WorkingDirectory=$SCRIPT_DIR/core/supreme
ExecStart=$(which node) bot.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
Environment=TAMERCLAW_HOME=$SCRIPT_DIR
Environment=HOME=$HOME
Environment=PATH=$svc_path
StandardOutput=journal
StandardError=journal
SyslogIdentifier=$SVC_SUPREME

[Install]
WantedBy=$SVC_WANTED_BY"

  # Persist systemd mode
  echo "$SYSTEMD_MODE" > "$SCRIPT_DIR/user/.systemd-mode"

  $SCTL daemon-reload 2>/dev/null || true
  $SCTL enable "$SVC_BRIDGE" "$SVC_SUPREME" 2>/dev/null || true

  if [ "$SYSTEMD_MODE" = "user" ]; then
    loginctl enable-linger "$(whoami)" 2>/dev/null || true
  fi

  info "Repair complete! Run: tamerclaw restart all"
}

# ── Powerup Command ─────────────────────────────────────────────────────────
# Sets up a full agency structure with engineering and marketing teams.
# Run after init or update: ./tamerclaw powerup
cmd_powerup() {
  banner

  # Must be initialized first
  if [ ! -f "$SCRIPT_DIR/user/config.json" ]; then
    err "TamerClaw not initialized. Run: tamerclaw init"
    exit 1
  fi

  # Load agency definition
  local agency_file="$SCRIPT_DIR/core/powerup/agency.json"
  if [ ! -f "$agency_file" ]; then
    err "Agency definition not found: $agency_file"
    err "Run: tamerclaw update   to get the latest version"
    exit 1
  fi

  echo ""
  echo -e "${BOLD}🚀 TamerClaw Agency Powerup${NC}"
  echo ""
  echo "This will set up a full software agency with specialized agents."
  echo "Each agent gets its own Telegram bot for direct communication."
  echo ""
  echo -e "${BOLD}═══ Agency Structure ═══${NC}"
  echo ""
  echo -e "  ${CYAN}1) CTO Agent${NC} — Engineering team leader"
  echo "     1.1 Flutter Developer (Mac Mini builds)"
  echo "     1.2 Frontend Developer (React/Next.js)"
  echo "     1.3 Backend Developer (APIs/databases)"
  echo "     1.4 Designer (UI/UX)"
  echo "     1.5 QA Engineer (testing)"
  echo ""
  echo -e "  ${CYAN}2) CMO Agent${NC} — Marketing team leader"
  echo "     2.1 Presentation Agent (slide decks)"
  echo "     2.2 Digital Marketing Specialist (SEO/social)"
  echo ""

  # Check which agents already exist
  local existing_agents
  existing_agents=$(node -e "
    const c = JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/user/config.json', 'utf-8'));
    console.log(Object.keys(c.agents || {}).join(','));
  " 2>/dev/null || echo "")

  local already_count=0
  local agent_ids=("cto" "flutter" "frontend" "backend" "designer" "qa" "cmo" "presentations" "digital-marketing")
  for aid in "${agent_ids[@]}"; do
    if echo ",$existing_agents," | grep -q ",$aid,"; then
      already_count=$((already_count + 1))
    fi
  done

  if [ "$already_count" -eq "${#agent_ids[@]}" ]; then
    warn "All agency agents already exist in config."
    ask "Reconfigure them? This will overwrite identities and team structure. (y/N):"
    read -r redo
    if [[ ! "$redo" =~ ^[Yy] ]]; then
      echo "Aborted."
      exit 0
    fi
  elif [ "$already_count" -gt 0 ]; then
    info "$already_count agent(s) already exist — they will be updated with agency identities."
  fi

  # Read user info from existing config
  local user_name
  user_name=$(node -e "
    const c = JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/user/config.json', 'utf-8'));
    console.log(c.system?.installedBy || 'User');
  " 2>/dev/null || echo "User")

  local telegram_id=""
  local allow_file="$SCRIPT_DIR/user/credentials/telegram-default-allowFrom.json"
  if [ -f "$allow_file" ]; then
    telegram_id=$(node -e "
      const a = JSON.parse(require('fs').readFileSync('$allow_file', 'utf-8'));
      if (a.users && a.users.length) console.log(a.users[0]);
    " 2>/dev/null || echo "")
  fi

  # ── Collect bot tokens ──
  echo -e "${BOLD}═══ Telegram Bot Setup ═══${NC}"
  echo ""
  echo "Create bots via @BotFather on Telegram. Each agent needs its own bot."
  echo "Press Enter to skip any agent you don't need right now."
  echo ""

  # Agent display names for prompts
  declare -A agent_display_names
  agent_display_names=(
    [cto]="CTO Agent"
    [flutter]="Flutter Developer"
    [frontend]="Frontend Developer"
    [backend]="Backend Developer"
    [designer]="Designer"
    [qa]="QA Engineer"
    [cmo]="CMO Agent"
    [presentations]="Presentation Agent"
    [digital-marketing]="Digital Marketing Specialist"
  )

  declare -A agent_tokens
  local configured_count=0
  local skipped_count=0

  # Engineering team
  echo -e "  ${BOLD}── Engineering Team ──${NC}"
  for aid in cto flutter frontend backend designer qa; do
    local display="${agent_display_names[$aid]}"
    local existing_token=""
    # Check if agent already has a token
    if echo ",$existing_agents," | grep -q ",$aid,"; then
      existing_token=$(node -e "
        const c = JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/user/config.json', 'utf-8'));
        const t = c.agents?.['$aid']?.botToken || '';
        if (t) console.log(t);
      " 2>/dev/null || echo "")
    fi

    if [ -n "$existing_token" ]; then
      ask "$display [has token — Enter to keep, or paste new]:"
    else
      ask "$display bot token (Enter to skip):"
    fi
    read -r token

    if [ -n "$token" ]; then
      agent_tokens[$aid]="$token"
      info "$display — token set"
      configured_count=$((configured_count + 1))
    elif [ -n "$existing_token" ]; then
      agent_tokens[$aid]="$existing_token"
      info "$display — keeping existing token"
      configured_count=$((configured_count + 1))
    else
      warn "$display — skipped (set later: tamerclaw set-token $aid <token>)"
      skipped_count=$((skipped_count + 1))
    fi
  done

  echo ""
  echo -e "  ${BOLD}── Marketing Team ──${NC}"
  for aid in cmo presentations digital-marketing; do
    local display="${agent_display_names[$aid]}"
    local existing_token=""
    if echo ",$existing_agents," | grep -q ",$aid,"; then
      existing_token=$(node -e "
        const c = JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/user/config.json', 'utf-8'));
        const t = c.agents?.['$aid']?.botToken || '';
        if (t) console.log(t);
      " 2>/dev/null || echo "")
    fi

    if [ -n "$existing_token" ]; then
      ask "$display [has token — Enter to keep, or paste new]:"
    else
      ask "$display bot token (Enter to skip):"
    fi
    read -r token

    if [ -n "$token" ]; then
      agent_tokens[$aid]="$token"
      info "$display — token set"
      configured_count=$((configured_count + 1))
    elif [ -n "$existing_token" ]; then
      agent_tokens[$aid]="$existing_token"
      info "$display — keeping existing token"
      configured_count=$((configured_count + 1))
    else
      warn "$display — skipped (set later: tamerclaw set-token $aid <token>)"
      skipped_count=$((skipped_count + 1))
    fi
  done

  echo ""
  info "Setting up $configured_count agent(s) ($skipped_count skipped)..."
  echo ""

  # ── Create agent directories and copy identities ──
