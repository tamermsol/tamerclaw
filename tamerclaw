# ── Manage.sh compatibility commands ──────────────────────────────────────────
cmd_send() {
  local agent_id="$1"
  local message="$2"
  if [ -z "$agent_id" ] || [ -z "$message" ]; then
    err "Usage: tamerclaw send <agentId> '<message>'"
    exit 1
  fi
  local gw_token
  gw_token=$(node -e "console.log(JSON.parse(require('fs').readFileSync('$SCRIPT_DIR/user/config.json','utf-8')).gateway.auth.token)" 2>/dev/null)
  curl -s -X POST -H "Authorization: Bearer $gw_token" -H "Content-Type: application/json" \
    -d "{\"message\":\"$message\"}" \
    "http://127.0.0.1:19789/api/agents/$agent_id/message" | node -e "
    let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
      try { console.log(JSON.parse(d).response || d); } catch { console.log(d); }
    })
  "
}

cmd_cron_list() {
  node -e "
    const fs = require('fs');
    const d = JSON.parse(fs.readFileSync('$SCRIPT_DIR/user/cron/jobs.json','utf-8'));
    if (d.jobs.length === 0) { console.log('No cron jobs.'); process.exit(0); }
    for (const j of d.jobs) {
      const sched = j.schedule.kind === 'at' ? 'at ' + j.schedule.at : j.schedule.cron;
      const status = j.enabled ? '✅' : '❌';
      console.log(status + ' ' + j.name.padEnd(30) + j.agentId.padEnd(12) + sched);
    }
  " 2>/dev/null
}

# ── Add Agent ─────────────────────────────────────────────────────────────────
cmd_add_agent() {
  local agent_id="$1"
  local agent_path="$2"

  if [ -z "$agent_id" ]; then
    err "Usage: tamerclaw add-agent <name> [path-to-existing-agent-dir]"
    exit 1
  fi

  mkdir -p "$SCRIPT_DIR/user/agents/$agent_id/memory"
  mkdir -p "$SCRIPT_DIR/user/agents/$agent_id/sessions"
  mkdir -p "$SCRIPT_DIR/user/agents/$agent_id/media"

  # Copy files from existing agent dir if provided
  if [ -n "$agent_path" ] && [ -d "$agent_path" ]; then
    for f in IDENTITY.md USER.md TOOLS.md MEMORY.md; do
      [ -f "$agent_path/$f" ] && cp "$agent_path/$f" "$SCRIPT_DIR/user/agents/$agent_id/$f"
    done
    info "Copied agent files from $agent_path"
  fi

  # Create skeleton IDENTITY.md if not exists
  if [ ! -f "$SCRIPT_DIR/user/agents/$agent_id/IDENTITY.md" ]; then
    cat > "$SCRIPT_DIR/user/agents/$agent_id/IDENTITY.md" << EOF
# $agent_id Agent

A Claude Code agent managed by TamerClaw.
EOF
  fi

  # Add to config
  node -e "
    const fs = require('fs');
    const configPath = '$SCRIPT_DIR/user/config.json';
    const c = JSON.parse(fs.readFileSync(configPath, 'utf-8'));
    if (c.agents['$agent_id']) {
      console.error('Agent already exists: $agent_id');
      process.exit(1);
    }
    c.agents['$agent_id'] = {
      botToken: '',
      workspace: '${agent_path:-}',
      identity: '$SCRIPT_DIR/user/agents/$agent_id/IDENTITY.md'
    };
    fs.writeFileSync(configPath, JSON.stringify(c, null, 2));
    console.log('✅ Agent added: $agent_id');
    console.log('Set token: tamerclaw set-token $agent_id <bot-token>');
  "
}

# ── Access Control ───────────────────────────────────────────────────────────
cmd_allow_all() {
  local allow_file="$SCRIPT_DIR/user/credentials/telegram-default-allowFrom.json"
  mkdir -p "$(dirname "$allow_file")"
  echo '{"allowAll":true}' > "$allow_file"
  info "Bot is now PUBLIC — anyone can message your agents"
  info "To restrict: tamerclaw restrict <telegram-user-id>"
}

cmd_restrict() {
  local user_id="${1:-}"
  local allow_file="$SCRIPT_DIR/user/credentials/telegram-default-allowFrom.json"
  mkdir -p "$(dirname "$allow_file")"
  if [ -z "$user_id" ]; then
    # Show current state
    if [ -f "$allow_file" ]; then
      echo "Current allowlist:"
      cat "$allow_file"
    else
      echo "No allowlist file — bot is open to all by default"
    fi
    echo ""
    echo "Usage: tamerclaw restrict <telegram-user-id>"
    return
  fi
  echo "{\"users\":[$user_id],\"allowAll\":false}" > "$allow_file"
  info "Bot restricted to Telegram user ID: $user_id"
}

# ── Doctor (diagnostics) ──────────────────────────────────────────────────────
cmd_doctor() {
  banner
  echo -e "${BOLD}TamerClaw Diagnostics${NC}"
  echo ""

  # Check Node.js
  local node_path
  node_path=$(which node 2>/dev/null || echo "")
  if [ -n "$node_path" ]; then
    local node_ver
    node_ver=$(node --version 2>/dev/null || echo "unknown")
    echo -e "  ${GREEN}✓${NC} Node.js: $node_ver ($node_path)"
  else
    echo -e "  ${RED}✗${NC} Node.js: NOT FOUND"
  fi

  # Check Claude CLI
  local claude_path
  claude_path=$(which claude 2>/dev/null || echo "")
  if [ -n "$claude_path" ]; then
    echo -e "  ${GREEN}✓${NC} Claude CLI: $claude_path"
  else
    echo -e "  ${RED}✗${NC} Claude CLI: NOT FOUND"
  fi

  # Check npm
  local npm_path
  npm_path=$(which npm 2>/dev/null || echo "")
  if [ -n "$npm_path" ]; then
    echo -e "  ${GREEN}✓${NC} npm: $(npm --version 2>/dev/null)"
  else
    echo -e "  ${RED}✗${NC} npm: NOT FOUND"
  fi

  echo ""

  # Check config
  if [ -f "$SCRIPT_DIR/user/config.json" ]; then
    echo -e "  ${GREEN}✓${NC} Config: $SCRIPT_DIR/user/config.json"
  else
    echo -e "  ${RED}✗${NC} Config: NOT FOUND (run: tamerclaw init)"
  fi

  # Check dependencies
  echo ""
  echo -e "${BOLD}Dependencies:${NC}"
  if [ -d "$SCRIPT_DIR/core/bridge/node_modules/node-telegram-bot-api" ]; then
    echo -e "  ${GREEN}✓${NC} Bridge: node_modules installed"
  else
    echo -e "  ${RED}✗${NC} Bridge: node_modules MISSING (run: cd core/bridge && npm install)"
  fi
  if [ -d "$SCRIPT_DIR/core/supreme/node_modules/node-telegram-bot-api" ]; then
    echo -e "  ${GREEN}✓${NC} Supreme: node_modules installed"
  else
    echo -e "  ${RED}✗${NC} Supreme: node_modules MISSING (run: cd core/supreme && npm install)"
  fi

  # Check systemd
  echo ""
  echo -e "${BOLD}Systemd ($SYSTEMD_MODE mode):${NC}"
  for svc in tamerclaw-bridge tamerclaw-supreme; do
    local svc_file="$SVC_DIR/${svc}.service"
    if [ -f "$svc_file" ]; then
      local status
      status=$($SCTL is-active "$svc" 2>/dev/null || echo "inactive")
      local failed=""
      if [ "$status" = "failed" ]; then
        failed=" — $(${SCTL} show "$svc" --property=Result --value 2>/dev/null || echo "unknown reason")"
      fi
      case "$status" in
        active)   echo -e "  ${GREEN}●${NC} $svc: running" ;;
        failed)   echo -e "  ${RED}●${NC} $svc: FAILED${failed}" ;;
        *)        echo -e "  ${YELLOW}●${NC} $svc: $status" ;;
      esac
    else
      echo -e "  ${RED}✗${NC} $svc: service file not found at $svc_file"
    fi
  done

  # Show recent errors for failed services
  echo ""
  for svc in tamerclaw-bridge tamerclaw-supreme; do
    local status
    status=$($SCTL is-active "$svc" 2>/dev/null || echo "inactive")
    if [ "$status" = "failed" ] || [ "$status" = "inactive" ]; then
      echo -e "${BOLD}Recent logs for $svc:${NC}"
      $JCTL -u "$svc" -n 20 --no-pager 2>/dev/null || echo "  (no logs available)"
      echo ""
    fi
  done

  # Check ExecStart path in service file
  echo -e "${BOLD}Service file checks:${NC}"
  for svc in tamerclaw-bridge tamerclaw-supreme; do
    local svc_file="$SVC_DIR/${svc}.service"
    if [ -f "$svc_file" ]; then
      local exec_start
      exec_start=$(grep "^ExecStart=" "$svc_file" 2>/dev/null | head -1)
      if [ -n "$exec_start" ]; then
        local node_bin
        node_bin=$(echo "$exec_start" | sed 's/ExecStart=//' | awk '{print $1}')
        if [ -x "$node_bin" ]; then
          echo -e "  ${GREEN}✓${NC} $svc: node binary exists ($node_bin)"
        else
          echo -e "  ${RED}✗${NC} $svc: node binary NOT FOUND at $node_bin"
          echo "    Fix: tamerclaw init (to regenerate service files)"
        fi
      fi
    fi
  done
}

# ── Main Dispatch ─────────────────────────────────────────────────────────────
case "${1:-}" in
  init)       cmd_init ;;
  update)     cmd_update ;;
  start)      cmd_start "${2:-}" "${3:-}" ;;
  stop)       cmd_stop "${2:-}" ;;
  restart|safe-restart)    cmd_restart "${2:-}" ;;
  status)     cmd_status ;;
  doctor)     cmd_doctor ;;
  logs)       cmd_logs "${2:-}" ;;
  set-token)  cmd_set_token "${2:-}" "${3:-}" ;;
  agents)     cmd_agents ;;
  test)       cmd_test "${2:-}" ;;
  test-claude) cmd_test_claude ;;
  send)       cmd_send "${2:-}" "${3:-}" ;;
  cron-list)  cmd_cron_list ;;
  add-agent)  cmd_add_agent "${2:-}" "${3:-}" ;;
  allow-all)  cmd_allow_all ;;
  restrict)   cmd_restrict "${2:-}" ;;
  version|-v|--version)
    echo "TamerClaw v${VERSION}"
    ;;
  help|-h|--help|"")
    banner
    echo "Commands:"
    echo ""
    echo "  ${BOLD}Setup:${NC}"
    echo "    init                   Initialize TamerClaw (interactive wizard)"
    echo "    update                 Pull latest updates and restart services"
    echo ""
    echo "  ${BOLD}Services:${NC}"
    echo "    start [target]         Start services (bridge|supreme|all|--foreground [bridge|supreme])"
    echo "    stop [target]          Stop services"
    echo "    restart [target]       Safe restart with health checks (bridge|supreme|all)"
    echo "    status                 Show system status"
    echo "    doctor                 Run diagnostics (check deps, services, config)"
    echo "    logs [target]          Tail logs (bridge|supreme|all)"
    echo ""
    echo "  ${BOLD}Agents:${NC}"
    echo "    agents                 List all agents"
    echo "    add-agent NAME [PATH]  Add a new agent"
    echo "    set-token ID TOKEN     Set Telegram bot token"
    echo "    test [ID|--all]        Test Telegram connections"
    echo "    test-claude            Verify Claude CLI works"
    echo "    send ID 'message'      Send message to agent"
    echo ""
    echo "  ${BOLD}Access:${NC}"
    echo "    allow-all              Make bot public (anyone can message)"
    echo "    restrict [USER_ID]     Restrict to specific Telegram user"
    echo ""
    echo "  ${BOLD}Cron:${NC}"
    echo "    cron-list              List scheduled jobs"
    echo ""
    echo "  ${BOLD}Other:${NC}"
    echo "    version                Show version"
    echo "    help                   Show this help"
    echo ""
    ;;
  *)
    err "Unknown command: $1"
    echo "Run 'tamerclaw help' for usage."
    exit 1
    ;;
esac
