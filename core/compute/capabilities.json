{
  "mac-mini": {
    "hardware": {
      "chip": "Apple M1",
      "cpu_cores": 8,
      "gpu_cores": 8,
      "ram_gb": 8,
      "storage_gb": 228,
      "os": "macOS 26.2 (Tahoe)"
    },
    "toolchain": {
      "xcode": { "version": "26.2", "path": "/Applications/Xcode.app" },
      "flutter": { "version": "3.41.6", "path": "~/flutter/bin/flutter", "channel": "stable" },
      "dart": { "version": "bundled", "path": "~/flutter/bin/dart" },
      "node": { "version": "25.8.2", "path": "/opt/homebrew/bin/node" },
      "npm": { "version": "bundled", "path": "/opt/homebrew/bin/npm" },
      "python3": { "version": "3.9.6", "path": "/usr/bin/python3" },
      "ffmpeg": { "version": "8.1", "path": "/opt/homebrew/bin/ffmpeg" },
      "cocoapods": { "version": "1.16.2", "path": "/opt/homebrew/bin/pod" },
      "ruby": { "version": "2.6.10", "path": "/usr/bin/ruby" },
      "homebrew": { "version": "5.1.3", "path": "/opt/homebrew/bin/brew" },
      "imagemagick": { "version": "pending", "path": "/opt/homebrew/bin/magick" },
      "whisper": { "version": "pending", "path": "~/compute-env/bin/whisper" }
    },
    "capabilities": {
      "flutter-build": {
        "description": "Build Flutter iOS/macOS apps natively on Apple Silicon",
        "commands": {
          "ios_build": "cd {project} && ~/flutter/bin/flutter build ios --release --no-codesign",
          "ios_debug": "cd {project} && ~/flutter/bin/flutter build ios --debug --no-codesign",
          "ios_simulator": "cd {project} && ~/flutter/bin/flutter build ios --simulator --debug",
          "macos_build": "cd {project} && ~/flutter/bin/flutter build macos --release",
          "analyze": "cd {project} && ~/flutter/bin/flutter analyze",
          "test": "cd {project} && ~/flutter/bin/flutter test",
          "pub_get": "cd {project} && ~/flutter/bin/flutter pub get"
        },
        "best_for": ["hbot", "david", "flutter"]
      },
      "voice-processing": {
        "description": "Transcribe audio with Whisper on Apple Silicon (fast Metal acceleration)",
        "commands": {
          "transcribe": "source ~/compute-env/bin/activate && whisper {input} --model base --language en --output_format txt --output_dir /tmp/claude-compute/",
          "transcribe_ar": "source ~/compute-env/bin/activate && whisper {input} --model medium --language ar --output_format txt --output_dir /tmp/claude-compute/",
          "convert_audio": "ffmpeg -i {input} -ar 16000 -ac 1 -c:a pcm_s16le {output}"
        },
        "best_for": ["supreme", "david", "amir", "hbot"]
      },
      "video-processing": {
        "description": "Video encoding/transcoding with FFmpeg (hardware-accelerated on M1)",
        "commands": {
          "compress": "ffmpeg -i {input} -c:v hevc_videotoolbox -b:v 2M -c:a aac -b:a 128k {output}",
          "extract_audio": "ffmpeg -i {input} -vn -acodec pcm_s16le -ar 16000 -ac 1 {output}",
          "thumbnail": "ffmpeg -i {input} -ss 00:00:01 -vframes 1 {output}",
          "gif": "ffmpeg -i {input} -vf 'fps=10,scale=480:-1:flags=lanczos' -c:v gif {output}"
        },
        "best_for": ["heygen", "amir", "mos-post", "branding"]
      },
      "image-processing": {
        "description": "Image manipulation with ImageMagick and Python PIL",
        "commands": {
          "resize": "magick {input} -resize {size} {output}",
          "convert": "magick {input} {output}",
          "composite": "magick {base} {overlay} -composite {output}",
          "app_icon": "magick {input} -resize 1024x1024 {output}"
        },
        "best_for": ["branding", "designer", "hbot-website", "mos-post"]
      },
      "ios-build-pipeline": {
        "description": "Full iOS build pipeline: pub get -> pod install -> build -> archive",
        "commands": {
          "full_build": "cd {project} && ~/flutter/bin/flutter pub get && cd ios && pod install && cd .. && ~/flutter/bin/flutter build ios --release --no-codesign",
          "full_simulator_build": "cd {project} && ~/flutter/bin/flutter pub get && cd ios && pod install && cd .. && ~/flutter/bin/flutter build ios --simulator --debug",
          "pod_install": "cd {project}/ios && pod install",
          "xcode_build": "xcodebuild -workspace {workspace} -scheme {scheme} -configuration Release -sdk iphoneos build"
        },
        "best_for": ["hbot", "david", "flutter"]
      },
      "node-services": {
        "description": "Run Node.js services, build Next.js/React apps on Apple Silicon",
        "commands": {
          "npm_build": "cd {project} && npm install && npm run build",
          "npm_test": "cd {project} && npm test",
          "next_build": "cd {project} && npm install && npx next build"
        },
        "best_for": ["msol", "hbot-website", "mos-v3-website", "mark", "fullstack"]
      }
    }
  }
}
