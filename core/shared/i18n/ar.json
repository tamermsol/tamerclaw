  "welcome": {
    "title": "\u0623\u0647\u0644\u0627\u064b \u0648\u0633\u0647\u0644\u0627\u064b!",
    "description": "\u0623\u0646\u0627 \u0645\u0633\u0627\u0639\u062f\u0643 \u0627\u0644\u0630\u0643\u064a \u0627\u0644\u0645\u062f\u0639\u0648\u0645 \u0628\u0648\u0627\u0633\u0637\u0629 Claude. \u0623\u0631\u0633\u0644 \u0644\u064a \u0631\u0633\u0627\u0644\u0629 \u0623\u0648 \u0627\u0633\u062a\u062e\u062f\u0645 `/chat` \u0644\u0628\u062f\u0621 \u0645\u062d\u0627\u062f\u062b\u0629.",
    "features": "**\u0645\u0627 \u064a\u0645\u0643\u0646\u0646\u064a \u0641\u0639\u0644\u0647:**\n\u2022 \u0627\u0644\u0625\u062c\u0627\u0628\u0629 \u0639\u0644\u0649 \u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0648\u0625\u062c\u0631\u0627\u0621 \u0645\u062d\u0627\u062f\u062b\u0627\u062a\n\u2022 \u0627\u0644\u0645\u0633\u0627\u0639\u062f\u0629 \u0641\u064a \u0627\u0644\u0628\u0631\u0645\u062c\u0629 \u0648\u0627\u0644\u0643\u062a\u0627\u0628\u0629 \u0648\u0627\u0644\u062a\u062d\u0644\u064a\u0644\n\u2022 \u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u0635\u0648\u0631 \u0648\u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0635\u0648\u062a\u064a\u0629\n\u2022 \u062a\u0630\u0643\u0631 \u0627\u0644\u0633\u064a\u0627\u0642 \u062e\u0644\u0627\u0644 \u0627\u0644\u062c\u0644\u0633\u0629\n\n**\u0628\u062f\u0627\u064a\u0629 \u0633\u0631\u064a\u0639\u0629:**\n\u2022 \u0627\u0643\u062a\u0628 \u0631\u0633\u0627\u0644\u0629 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0642\u0646\u0627\u0629\n\u2022 \u0627\u0633\u062a\u062e\u062f\u0645 `/help` \u0644\u0639\u0631\u0636 \u062c\u0645\u064a\u0639 \u0627\u0644\u0623\u0648\u0627\u0645\u0631\n\u2022 \u0627\u0633\u062a\u062e\u062f\u0645 `/lang en` \u0644\u0644\u062a\u0628\u062f\u064a\u0644 \u0625\u0644\u0649 \u0627\u0644\u0625\u0646\u062c\u0644\u064a\u0632\u064a\u0629"
