# User data — never committed
user/

# Node
node_modules/
core/bridge/node_modules/
core/relay/node_modules/
core/supreme/node_modules/

# Runtime state files (should live in user/ but may be created by old versions)
core/relay/proxy-state.json
core/shared/rate-usage.json
core/relay/outbox/
core/relay/stream-outbox/
core/relay/inbox.jsonl
core/relay/processed.txt
core/relay/current-agent.txt
core/relay/processing.json
core/relay/session-owners.json
core/relay/agent-sessions.json
core/relay/health.json
core/relay/bot.lock
core/supreme/outbox/
core/supreme/inbox.jsonl
core/supreme/processed.txt
core/supreme/processing.json
core/supreme/health.json
core/supreme/bot.lock

# Runtime logs
*.log
bridge.log

# Fix/migration scripts (generated locally)
fix-*.sh

# OS
.DS_Store
*.swp
*.swo

# Lockfiles generated locally
package-lock.json

# Stray binaries / transcriptions
*.apk
*.oga

# Mobile app artifacts
mobile/*.apk
mobile/build/
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/android/.gradle/
mobile/android/app/build/
mobile/android/local.properties
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/.metadata

# Agent memory
.claude/
